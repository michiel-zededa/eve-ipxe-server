# ─── eve-ipxe-server environment variables ────────────────────────────────────
# Copy this file to .env and edit the values before running `docker compose up`.
# Only SERVER_HOST needs to be set for a functional deployment; everything
# else has reasonable defaults.

# ── Network ───────────────────────────────────────────────────────────────────

# IP address of THIS host as seen by PXE clients on the local network.
# Used to construct kernel, initrd, and iPXE script HTTP URLs.
# If left blank the backend will attempt auto-detection from the first
# non-loopback interface — set it explicitly when auto-detection is unreliable
# (e.g. multi-homed hosts, Docker Desktop on macOS/Windows).
SERVER_HOST=192.168.1.10

# Host address that the webui and nginx ports bind to.
# Set to a specific interface IP to restrict exposure.
BIND_ADDRESS=0.0.0.0

# TCP port for the Web UI / API (container always uses 8080 internally).
WEBUI_PORT=8080

# TCP port nginx uses to serve large artifact files (kernel, initrd, ISOs).
HTTP_PORT=8081

# Network interface for the optional dnsmasq DHCP service.
# Only relevant when starting the stack with: docker compose --profile dnsmasq up
INTERFACE=eth0

# ── dnsmasq (optional DHCP) ───────────────────────────────────────────────────
# DHCP address pool range and lease time.
DHCP_RANGE=192.168.1.100,192.168.1.200,12h

# Default gateway pushed to DHCP clients (leave blank to not set).
DHCP_ROUTER=192.168.1.1

# DNS server pushed to DHCP clients (leave blank to not set).
DHCP_DNS=8.8.8.8

# ── GitHub API ────────────────────────────────────────────────────────────────
# Personal access token for the GitHub API.
# Without a token the API is limited to 60 requests/hour (usually sufficient).
# Create one at https://github.com/settings/tokens — no scopes required for
# public repository access.
GITHUB_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────────────
# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info
