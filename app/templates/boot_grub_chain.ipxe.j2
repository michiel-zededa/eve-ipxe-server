#!ipxe
##############################################################################
#  EVE-OS iPXE Boot Script — GRUB-Chain mode (EVE v12+)
#
#  Generated by eve-ipxe-server for config: {{ config.name }}
#  EVE version : {{ config.eve_version }}
#  Architecture: {{ config.architecture }}
#  HV mode     : {{ config.hv_mode }}
#  Variant     : {{ config.variant }}
#  Scenario    : {{ config.scenario }}
#  Controller  : {{ config.controller_url or '(none)' }}
#
#  Boot flow:
#    iPXE → GRUB EFI binary → loop-mounts installer.iso → kernel+initrd
#
#  Installation parameters are embedded in EFI/BOOT/grub.cfg on the
#  artifact server.  No interactive grub menu is shown (timeout=0).
##############################################################################

echo
echo ============================================================
echo   EVE-OS iPXE Boot Server
echo   Version : {{ config.eve_version }}   Arch: {{ config.architecture }}
echo   Config  : {{ config.name }}
echo   Server  : {{ artifact_http_base }}/
echo ============================================================
echo

# ── Base URL for all artifact files (kernel, ISO, GRUB EFI) ──────────────────
# The trailing slash is required by GRUB's HTTP client.
set url {{ artifact_http_base }}/

# ── Console ───────────────────────────────────────────────────────────────────
{% set consoles = config.console.split() if config.console else ['tty0', 'ttyS0,115200n8'] %}
set console {% for c in consoles %}console={{ c }}{% if not loop.last %} {% endif %}{% endfor %}

# ── Vendor-specific console tweaks ────────────────────────────────────────────
iseq ${smbios/manufacturer} Huawei      && set console console=ttyAMA0,115200n8 ||
iseq ${smbios/manufacturer} Supermicro  && set console console=ttyS1,115200n8   ||
iseq ${smbios/manufacturer} QEMU        && set console console=hvc0 console=ttyS0 ||

# ── NTP (uncomment if deploying on boards without RTC, e.g. Raspberry Pi) ────
# echo Syncing time via NTP...
# :retry_ntp
# ntp pool.ntp.org || goto retry_ntp

# ── Chain to GRUB EFI ─────────────────────────────────────────────────────────
# The GRUB binary fetches EFI/BOOT/grub.cfg from ${url} over HTTP.
# The grub.cfg has been pre-patched with installation parameters
# (eve_install_disk, dom0_extra_args, timeout=0, etc.) by eve-ipxe-server.
#
# x86_64 UEFI
iseq ${buildarch} x86_64  && chain --autofree ${url}EFI/BOOT/BOOTX64.EFI   ||
# ARM64 UEFI
iseq ${buildarch} arm64   && chain --autofree ${url}EFI/BOOT/BOOTAA64.EFI  ||
# RISC-V (if present)
iseq ${buildarch} riscv64 && chain --autofree ${url}EFI/BOOT/BOOTRISCV64.EFI ||

# ── BIOS / legacy fallback — sanboot the installer ISO ───────────────────────
# This works on BIOS systems where EFI chain-loading is not available.
# The installer.iso is El Torito compliant and supports legacy BIOS boot.
echo UEFI chain-load not available for ${buildarch}. Trying sanboot...
echo Note: install parameters are NOT pre-configured in sanboot mode.
echo Please configure the disk target interactively in the grub menu.
sanboot --no-describe ${url}installer.iso || goto failed

:failed
echo
echo ERROR: All boot methods failed.
echo Please open the web UI at http://{{ server }}:{{ webui_port }} and verify
echo the artifacts were downloaded correctly.
echo
prompt --key s --timeout 30 Press s to open a shell, or wait to reboot... && shell || reboot
