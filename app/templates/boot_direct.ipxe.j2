#!ipxe
##############################################################################
#  EVE-OS iPXE Boot Script — Direct mode (pre-EVE v12)
#
#  Generated by eve-ipxe-server for config: {{ config.name }}
#  EVE version : {{ config.eve_version }}
#  Architecture: {{ config.architecture }}
#  HV mode     : {{ config.hv_mode }}
#  Variant     : {{ config.variant }}
#  Scenario    : {{ config.scenario }}
#  Controller  : {{ config.controller_url or '(none)' }}
#
#  Boot flow: iPXE → kernel + initrd.img (no GRUB intermediary)
#
#  All EVE installation parameters are embedded in the kernel command line.
##############################################################################

echo
echo ============================================================
echo   EVE-OS iPXE Boot Server  [direct / pre-v12 mode]
echo   Version : {{ config.eve_version }}   Arch: {{ config.architecture }}
echo   Config  : {{ config.name }}
echo   Install → {{ config.install_disk }}
{% if config.controller_url %}
echo   Server  → {{ config.controller_url }}
{% endif %}
echo ============================================================
echo

set base {{ artifact_http_base }}

echo Fetching kernel from ${base}/kernel ...
kernel ${base}/kernel {{ kernel_cmdline }} || goto failed

echo Fetching initrd from ${base}/initrd.img ...
initrd ${base}/initrd.img || goto failed

echo
echo Booting EVE-OS installer...
boot || goto failed

:failed
echo
echo ERROR: Boot failed.
echo Please open the web UI at http://{{ server }}:{{ webui_port }} to verify the
echo artifacts are downloaded and the configuration is correct.
echo
prompt --key s --timeout 30 Press s to drop to shell, or wait to reboot... && shell || reboot
